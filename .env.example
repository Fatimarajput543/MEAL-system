# Server Configuration
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=meal_user
DB_PASSWORD=secure_password
DB_DATABASE=meal_system
DB_LOGGING=false
DB_SYNCHRONIZE=false

# Authentication
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_EXPIRY=24h
JWT_REFRESH_SECRET=your_refresh_secret_key
JWT_REFRESH_EXPIRY=7d

# Azure AD Configuration
AZURE_TENANT_ID=your_tenant_id
AZURE_CLIENT_ID=your_client_id
AZURE_CLIENT_SECRET=your_client_secret
AZURE_REDIRECT_URI=http://localhost:3000/auth/callback

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# S3 Configuration
S3_ENDPOINT=https://s3.amazonaws.com
S3_ACCESS_KEY_ID=your_access_key
S3_SECRET_ACCESS_KEY=your_secret_key
S3_BUCKET_NAME=meal-system-bucket
S3_REGION=us-east-1

# Agresso ERP Integration
AGRESSO_API_URL=https://agresso.example.com/api
AGRESSO_API_KEY=your_agresso_key
AGRESSO_SYNC_ENABLED=true
AGRESSO_SYNC_INTERVAL=86400

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# CORS
CORS_ORIGIN=http://localhost:3001
